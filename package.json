{
  "name": "ha-pc-cam-monitor",
  "productName": "Camera Monitor",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "node create-icon.js && electron .",
    "build": "node create-icon.js && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.homeassistant.cameramonitor",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "**/*",
      "!stream/**/*",
      "!.env",
      "!config.json",
      "!.env.local",
      "!**/*.log"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Camera Monitor",
      "artifactName": "Cam Monitor Setup.${ext}"
    },
    "extraResources": [
      {
        "from": "icon.png",
        "to": "icon.png",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "hls.js": "^1.6.15"
  }
}
